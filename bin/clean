#!/usr/bin/env python3

import base64
import errno
import json
import os
import re
import sys
import unicodedata
import zlib
from datetime import datetime
from difflib import SequenceMatcher
from dataclasses import dataclass, field
from pathlib import Path


GENERIC_REMIX_TAGS = {"Segue", "Mash", "Remix"}
INTRO_SUPPRESSING_TAGS = {"Acapella In", "Acapella Out", "Acapella In & Out", "Slam Edit", "Ext", "Clapapella", "Jump Off Edit"}
TRANSITION_PREFIX_DROP_PATTERNS = [
    r"\bhip\s+hop\s+to\s+house\b",
    r"\bvip\s+flip\b",
    r"\bflip\b",
    r"\bedit\b",
]
REMOVED_TAG_PATTERNS = []
REDUNDANT_INTRO_TAGS = {
    "Acapella Intro",
    "Hype Intro",
    "Hype In",
    "Epic Intro",
    "Epic In",
    "Break Intro",
    "Break In",
}
STANDARD_MAIN_TAGS = {
    "Segue",
    "Mash",
    "Remix",
    "Slam Edit",
    "Clapapella",
    "Ext",
    "Instrumental",
    "Original Mix",
    "Jump Off Edit",
    "Acapella",
    "Acapella In",
    "Acapella Out",
    "Acapella In & Out",
    "Acapella Intro",
    "Hype Intro",
    "Hype In",
    "Epic Intro",
    "Epic In",
    "Break Intro",
    "Break In",
}

COLOR_RESET = "\033[0m"
COLOR_DIM = "\033[2m"
COLOR_RED = "\033[31m"
COLOR_GREEN = "\033[32m"
COLOR_CYAN = "\033[36m"
COLOR_BRIGHT_CYAN = "\033[96m"
COLOR_BLUE = "\033[34m"
COLOR_MAGENTA = "\033[35m"
COLOR_YELLOW = "\033[33m"
ANSI_PATTERN = re.compile(r"\x1b\[[0-9;]*m")
REVERT_DATA_PREFIX = "REVERT_DATA_V1:"
DELETED_SENTINEL = "[deleted]"
SCRIPT_PATH = Path(__file__).resolve()
BIN_DIR = SCRIPT_PATH.parent
REPO_ROOT = BIN_DIR.parent
SORT_FOLDER_COLORS = [COLOR_CYAN, COLOR_MAGENTA, COLOR_YELLOW, COLOR_BLUE, COLOR_MAGENTA, COLOR_BRIGHT_CYAN]


@dataclass
class FilenameState:
    artist: str
    song: str
    main_tags: list[str] = field(default_factory=list)
    edit_kind: str | None = None
    edit_tone: str | None = None
    remix_replaced: bool = False
    in_house: bool = False
    explicit_intro_edit: bool = False
    explicit_acapella_intro_source: bool = False


def normalize_spaces(text):
    return re.sub(r"\s+", " ", text).strip()


def canonical_filename_key(name):
    return unicodedata.normalize("NFC", name).casefold()


def is_existing_destination_error(error):
    if isinstance(error, FileExistsError):
        return True
    if isinstance(error, OSError):
        if getattr(error, "winerror", None) == 183:
            return True
        if getattr(error, "errno", None) == errno.EEXIST:
            return True
    return False


def title_case_phrase(text):
    return " ".join(word[:1].upper() + word[1:] if word else word for word in text.split())


def strip_outer_parens(text):
    text = text.strip()
    if text.startswith("(") and text.endswith(")"):
        return text[1:-1].strip()
    return text


def remove_wordplay_tokens(text):
    text = re.sub(r"\bword\s*play\s+edit\b", "Transition", text, flags=re.IGNORECASE)
    text = re.sub(r"\bword\s*play\b", " ", text, flags=re.IGNORECASE)
    return normalize_spaces(text)


def remove_discarded_tag_phrases(text):
    for pattern in REMOVED_TAG_PATTERNS:
        text = re.sub(pattern, " ", text, flags=re.IGNORECASE)
    return normalize_spaces(text)


def strip_tone_words(text):
    text = re.sub(r"\b(clean|dirty)\b", " ", text, flags=re.IGNORECASE)
    return normalize_spaces(text)


def cleanup_bad_dash(text):
    text = normalize_spaces(text)
    text = re.sub(r"^\-\s*", "", text)
    text = re.sub(r"\s*\-$", "", text)
    return normalize_spaces(text)


def remove_generic_remix_words(text):
    text = re.sub(r"\b(segway|segue|blend|mashup|mash|remix)\b", " ", text, flags=re.IGNORECASE)
    return cleanup_bad_dash(text)


def is_intro_suppressed(state):
    for tag in state.main_tags:
        if tag in INTRO_SUPPRESSING_TAGS or tag.endswith(" Transition"):
            return True
    return False


def intro_suppressor_tags(state):
    suppressors = []
    for tag in state.main_tags:
        if tag in INTRO_SUPPRESSING_TAGS or tag.endswith(" Transition"):
            suppressors.append(tag)
    return suppressors


def has_remix_tag(state):
    return any(re.search(r"\b(remix|segue|mash)\b", tag, flags=re.IGNORECASE) for tag in state.main_tags)


def has_club_edit_tag(state):
    return any(re.search(r"\bclub\s+edit\b", tag, flags=re.IGNORECASE) for tag in state.main_tags)


def has_redundant_intro_tag(state):
    return any(tag in REDUNDANT_INTRO_TAGS for tag in state.main_tags)


def is_standard_main_tag(tag):
    if tag in STANDARD_MAIN_TAGS:
        return True
    if tag.endswith(" Transition"):
        return True
    if re.fullmatch(r"Acapella (?:In|Out|Intro) .+", tag):
        return True
    if re.fullmatch(r"Acapella .+", tag):
        return True
    return False


def has_implicit_remix_artist_tag(state):
    return any(not is_standard_main_tag(tag) for tag in state.main_tags)


def harmonize_edit_tag(state):
    if "Instrumental" in state.main_tags:
        state.edit_kind = None
        state.edit_tone = None
        return
    if not state.edit_tone:
        return
    if state.in_house:
        if state.edit_kind == "intro":
            state.edit_kind = "plain"
        return
    suppressors = intro_suppressor_tags(state)
    if suppressors:
        if state.edit_kind == "intro":
            state.edit_kind = "plain"
        return
    has_redundant_intro = has_redundant_intro_tag(state)
    if has_redundant_intro and state.edit_kind == "plain":
        state.edit_kind = "intro"
    if has_implicit_remix_artist_tag(state) and state.edit_kind == "plain":
        state.edit_kind = "intro"
    if has_club_edit_tag(state) and state.edit_kind == "plain":
        state.edit_kind = "intro"
    if has_remix_tag(state) and state.edit_kind == "plain" and not state.remix_replaced:
        state.edit_kind = "intro"


def is_duplicate_suffix_file(filename):
    stem, _ = os.path.splitext(filename)
    return re.search(r"\s*\(\d+\)$", stem) is not None


def remove_noise_tokens(text):
    text = re.sub(r"\bClub\s+Killers\b", " ", text, flags=re.IGNORECASE)
    text = re.sub(r"\bCK\b(?!\s+Cut\b)\s*", " ", text)
    return remove_discarded_tag_phrases(normalize_spaces(text))


def normalize_artist_names(text):
    replacements = [
        (r"\bAAP\s+Rocky\b", "A$AP Rocky"),
        (r"\bASAP\s+Rocky\b", "A$AP Rocky"),
        (r"\bASAP\s+Ferg\b", "A$AP Ferg"),
        (r"\bTy\s+Dolla\s+Sign\b", "Ty Dolla $ign"),
        (r"\bToo\s+Short\b", "Too $hort"),
        (r"\bSchoolboy\s+Q\b", "ScHoolboy Q"),
        (r"\bJayZ\b", "Jay-Z"),
        (r"\bBiggie\s+Smalls\b", "The Notorious B.I.G."),
        (r"\bBiggie\b", "The Notorious B.I.G."),
        (r"\bDr\s+Dre\b", "Dr. Dre"),
    ]

    for pattern, replacement in replacements:
        text = re.sub(pattern, replacement, text, flags=re.IGNORECASE)

    return normalize_spaces(text)


def normalize_artist_segment(artist):
    artist = re.sub(r"\bfeat\.?\b", "ft", artist, flags=re.IGNORECASE)
    artist = re.sub(r"\s*,\s*", " x ", artist)
    artist = re.sub(r"\s*&\s*", " x ", artist)
    artist = re.sub(r"(?:^|\s)x(?:\s+x)+(?:\s|$)", " x ", artist)
    artist = normalize_artist_names(artist)
    return normalize_spaces(artist)


def normalize_artist_like_tag(text):
    text = re.sub(r"\bfeat\.?\b", "ft", text, flags=re.IGNORECASE)
    text = re.sub(r"\s*,\s*", " x ", text)
    text = re.sub(r"\s*&\s*", " x ", text)
    text = re.sub(r"(?:^|\s)x(?:\s+x)+(?:\s|$)", " x ", text)
    text = normalize_artist_names(text)
    return normalize_spaces(text)


def normalize_song_text(song):
    song = re.sub(r"\bvs\.\b", "vs", song, flags=re.IGNORECASE)
    song = re.sub(r"\bvs\.?(?=\s)", "vs", song, flags=re.IGNORECASE)
    song = normalize_artist_names(song)
    return normalize_spaces(song)


def remove_extra_predash_song_dash(rest):
    first_paren = rest.find("(")
    prefix = rest if first_paren == -1 else rest[:first_paren]
    suffix = "" if first_paren == -1 else rest[first_paren:]
    prefix = re.sub(r"\s+-\s+", " ", prefix)
    return normalize_spaces(prefix + suffix)


def split_filename(filename):
    if " - " not in filename:
        cleaned = normalize_artist_names(normalize_spaces(filename))
        return FilenameState(artist=cleaned, song="")

    artist, rest = filename.split(" - ", 1)
    artist = normalize_artist_segment(artist)
    rest = remove_extra_predash_song_dash(rest)

    chunk_matches = list(re.finditer(r"\([^()]*\)", rest))
    chunks = []
    loose_parts = []

    if chunk_matches:
        song = rest[:chunk_matches[0].start()].strip()
        cursor = chunk_matches[0].start()
        for match in chunk_matches:
            loose_parts.append(rest[cursor:match.start()])
            chunks.append(match.group(0)[1:-1].strip())
            cursor = match.end()
        loose_parts.append(rest[cursor:])
    else:
        song = rest.strip()

    return FilenameState(
        artist=artist,
        song=normalize_song_text(song),
        main_tags=chunks + ([normalize_spaces(" ".join(loose_parts))] if chunk_matches else []),
    )


def remove_kbpm_from_text(text):
    text = re.sub(r"\b\d{1,2}[AB]\b\s+\d{2,3}\b", " ", text, flags=re.IGNORECASE)
    text = re.sub(r"\b\d{2,3}\b\s+[AB]\b", " ", text, flags=re.IGNORECASE)
    text = re.sub(r"\b[AB]\b\s+\d{2,3}\b", " ", text, flags=re.IGNORECASE)
    text = re.sub(r"\b\d{2,3}\s+\d{1,2}[AB]\b", " ", text, flags=re.IGNORECASE)
    text = re.sub(r"\b\d{1,2}[AB]\b", " ", text, flags=re.IGNORECASE)
    return normalize_spaces(text)


def add_main_tag(state, text):
    text = strip_outer_parens(normalize_spaces(text))
    if text:
        state.main_tags.append(text)


def set_edit(state, kind=None, tone=None):
    priority = {None: 0, "plain": 1, "quick_hit": 2, "intro": 3}
    if kind and priority[kind] >= priority[state.edit_kind]:
        state.edit_kind = kind
    if tone:
        state.edit_tone = tone


def parse_tone(text):
    lower = text.lower()
    if "clean" in lower:
        return "Clean"
    if "dirty" in lower:
        return "Dirty"
    return None


def apply_edit_from_text(state, text):
    lower = remove_discarded_tag_phrases(text).lower()
    tone = parse_tone(text)

    if re.search(r"\bintro\s*-?\s*(clean|dirty)\b", lower):
        set_edit(state, kind="intro", tone=tone)
        state.explicit_intro_edit = True
        return True

    if re.search(r"\b(clean|dirty)\s+extended\b", lower):
        if state.in_house:
            add_main_tag(state, "Ext")
            set_edit(state, kind="plain", tone=tone)
        else:
            set_edit(state, kind="intro", tone=tone)
            state.explicit_intro_edit = True
        return True

    if re.search(r"\b(clean|dirty)\s+(short\s+edit|ck\s+cut)\b", lower):
        set_edit(state, kind="quick_hit", tone=tone)
        return True

    if re.search(r"\bquick\s+hit\s+(clean|dirty)\b", lower):
        set_edit(state, kind="quick_hit", tone=tone)
        return True

    if re.search(r"\b(clean|dirty)\s+radio\s+edit\b", lower):
        if state.in_house:
            add_main_tag(state, "Original Mix")
        set_edit(state, kind="plain", tone=tone)
        return True

    if state.in_house and re.fullmatch(r"radio\s+edit", lower):
        add_main_tag(state, "Original Mix")
        return True

    if re.fullmatch(r"radio\s+edit", lower):
        return True

    if re.fullmatch(r"(clean|dirty)", lower):
        set_edit(state, kind="plain", tone=tone)
        return True

    return False


def normalize_range_text(range_text):
    match = re.search(r"(\d{2,3})\s*-\s*(\d{2,3})", range_text)
    if not match:
        return None
    return f"{match.group(1)}-{match.group(2)} Transition"


def split_prefix_and_suffix(text, suffix_pattern):
    match = re.match(rf"^(.*?)(?:\s+)?{suffix_pattern}$", text, flags=re.IGNORECASE)
    if not match:
        return None, None
    prefix = normalize_spaces(match.group(1))
    return prefix, True


def split_transition_prefix(prefix):
    prefix = normalize_spaces(prefix)
    if not prefix:
        return ""

    for pattern in TRANSITION_PREFIX_DROP_PATTERNS:
        match = re.search(pattern, prefix, flags=re.IGNORECASE)
        if match:
            prefix = prefix[:match.start()]
            break

    return normalize_spaces(prefix)


def extract_transition_tags(state, text):
    text = remove_discarded_tag_phrases(remove_wordplay_tokens(text))

    match = re.match(
        r"^(.*?)(\d{2,3}\s*-\s*\d{2,3})\s*(trans|transition)$",
        text,
        flags=re.IGNORECASE,
    )
    if match:
        prefix = split_transition_prefix(match.group(1))
        transition = normalize_range_text(match.group(2))
        if prefix:
            add_main_tag(state, normalize_artist_like_tag(prefix))
        add_main_tag(state, transition)
        return True

    match = re.match(
        r"^(.*?)\b(trans|transition)\s+(\d{2,3}\s*-\s*\d{2,3})$",
        text,
        flags=re.IGNORECASE,
    )
    if match:
        prefix = split_transition_prefix(match.group(1))
        transition = normalize_range_text(match.group(3))
        if prefix:
            add_main_tag(state, normalize_artist_like_tag(prefix))
        add_main_tag(state, transition)
        return True

    match = re.search(r"(\d{2,3}\s*-\s*\d{2,3})", text, flags=re.IGNORECASE)
    if match:
        prefix = split_transition_prefix(text[:match.start()])
        transition = normalize_range_text(match.group(1))
        if prefix:
            add_main_tag(state, normalize_artist_like_tag(prefix))
        add_main_tag(state, transition)
        return True

    return False


def normalize_acapella_tag(state, text):
    tone = parse_tone(text)
    text = remove_discarded_tag_phrases(strip_tone_words(text))

    both_pattern = r"^(.*?)(?:acapella|acap)\s+(?:intro|in)\s*(?:and|&)\s*(?:outro|out)(.*)$"
    match = re.search(both_pattern, text, flags=re.IGNORECASE)
    if match:
        prefix = normalize_spaces(match.group(1))
        suffix = normalize_spaces(match.group(2))
        if prefix:
            add_main_tag(state, normalize_artist_like_tag(prefix))
        add_main_tag(state, "Acapella In & Out")
        if suffix:
            add_main_tag(state, title_case_phrase(suffix))
        if tone:
            set_edit(state, kind="plain", tone=tone)
        return True

    if state.explicit_acapella_intro_source:
        match = re.search(r"^(.*?)\bacapella\s+intro\b(.*)$", text, flags=re.IGNORECASE)
        if match:
            prefix = normalize_spaces(match.group(1))
            suffix = normalize_spaces(match.group(2))
            if prefix:
                add_main_tag(state, normalize_artist_like_tag(prefix))
            tag = "Acapella Intro" if not suffix else f"Acapella Intro {title_case_phrase(suffix)}"
            add_main_tag(state, tag)
            if tone:
                set_edit(state, kind="plain", tone=tone)
            return True

    for pattern, replacement in [
        (r"^(.*?)(?:acapella|acap)\s+(?:intro|in)(.*)$", "Acapella In"),
        (r"^(.*?)(?:acapella|acap)\s+(?:outro|out)(.*)$", "Acapella Out"),
        (r"^(.*?)(?:acapella|acap)(.*)$", "Acapella"),
    ]:
        match = re.search(pattern, text, flags=re.IGNORECASE)
        if match:
            prefix = normalize_spaces(match.group(1))
            suffix = normalize_spaces(match.group(2))
            if prefix:
                add_main_tag(state, normalize_artist_like_tag(prefix))
            tag = replacement if not suffix else f"{replacement} {title_case_phrase(suffix)}"
            add_main_tag(state, tag)
            if tone:
                set_edit(state, kind="plain", tone=tone)
            return True

    return False


def normalize_special_intro_tag(state, text):
    tone = parse_tone(text)
    text = remove_discarded_tag_phrases(strip_tone_words(text))

    if re.fullmatch(r"intro", text, flags=re.IGNORECASE):
        set_edit(state, kind="intro", tone=tone)
        return True

    for pattern, replacement in [
        (r"\bparty\s+starter\b", "Clapapella"),
        (r"\bclap\s+(?:intro|in)\b", "Clapapella"),
        (r"\bslam\s+(?:intro|in)\b", "Slam Edit"),
        (r"\bslam\s+edit\b", "Slam Edit"),
    ]:
        if re.search(pattern, text, flags=re.IGNORECASE):
            prefix = re.sub(pattern, "", text, flags=re.IGNORECASE)
            prefix = normalize_spaces(prefix)
            if prefix:
                add_main_tag(state, normalize_artist_like_tag(prefix))
            add_main_tag(state, replacement)
            if tone:
                set_edit(state, kind="plain", tone=tone)
            return True

    for pattern, replacement in [
        (r"\bacapella\s+intro\b", "Acapella Intro"),
        (r"\bhype\s+intro\b", "Hype Intro"),
        (r"\bhype\s+in\b", "Hype In"),
        (r"\bepic\s+intro\b", "Epic Intro"),
        (r"\bepic\s+in\b", "Epic In"),
        (r"\bbreak\s+intro\b", "Break Intro"),
        (r"\bbreak\s+in\b", "Break In"),
    ]:
        if re.search(pattern, text, flags=re.IGNORECASE):
            prefix = re.sub(pattern, "", text, flags=re.IGNORECASE)
            prefix = normalize_spaces(prefix)
            if prefix:
                add_main_tag(state, normalize_artist_like_tag(prefix))
            add_main_tag(state, replacement)
            if tone:
                set_edit(state, kind="plain", tone=tone)
            return True

    return False


def normalize_quick_hitter_tag(state, text):
    match = re.match(r"^(.*?)\bquick\s+hitter\s+edit$", text, flags=re.IGNORECASE)
    if not match:
        return False

    prefix = normalize_spaces(match.group(1))
    if prefix:
        add_main_tag(state, normalize_artist_like_tag(prefix))
    set_edit(state, kind="quick_hit")
    return True


def normalize_jump_off_tag(state, text):
    match = re.match(r"^(.*?)\bjump\s+off(?:\s+edit)?$", text, flags=re.IGNORECASE)
    if not match:
        return False

    prefix = normalize_spaces(match.group(1))
    if prefix:
        add_main_tag(state, normalize_artist_like_tag(prefix))
    add_main_tag(state, "Jump Off Edit")
    return True


def normalize_extended_mix_tag(state, text):
    if re.fullmatch(r"extended\s+mix", text, flags=re.IGNORECASE):
        add_main_tag(state, "Ext")
        return True
    return False


def normalize_instrumental_tag(state, text):
    if re.fullmatch(r"inst|instrumental", text, flags=re.IGNORECASE):
        add_main_tag(state, "Instrumental")
        return True
    return False


def normalize_generic_remix_tag(state, text):
    text = re.sub(r"\bsegway\b", "Segue", text, flags=re.IGNORECASE)
    text = re.sub(r"\bblend\b|\bmashup\b", "Mash", text, flags=re.IGNORECASE)
    text = normalize_spaces(text)

    if re.fullmatch(r"segue|mash|remix|set\s+edit", text, flags=re.IGNORECASE):
        if re.fullmatch(r"set\s+edit", text, flags=re.IGNORECASE):
            add_main_tag(state, "Set Edit")
        else:
            add_main_tag(state, text.title() if text.lower() != "remix" else "Remix")
        return True

    match = re.match(r"^(.*?)(?:\s+)(Segue|Mash|Remix|Set\s+Edit)$", text, flags=re.IGNORECASE)
    if match:
        prefix = normalize_artist_like_tag(match.group(1))
        if prefix:
            add_main_tag(state, prefix)
        split_tag = match.group(2)
        if re.fullmatch(r"set\s+edit", split_tag, flags=re.IGNORECASE):
            add_main_tag(state, "Set Edit")
        else:
            add_main_tag(state, split_tag.title() if split_tag.lower() != "remix" else "Remix")
        return True

    add_main_tag(state, normalize_artist_like_tag(text))
    return True


def normalize_parenthetical_chunk(state, chunk):
    text = remove_noise_tokens(remove_wordplay_tokens(remove_kbpm_from_text(strip_outer_parens(chunk))))
    if not text:
        return

    if apply_edit_from_text(state, text):
        return
    if normalize_extended_mix_tag(state, text):
        return
    if normalize_instrumental_tag(state, text):
        return
    if extract_transition_tags(state, text):
        return
    if normalize_acapella_tag(state, text):
        return
    if normalize_special_intro_tag(state, text):
        return
    if normalize_quick_hitter_tag(state, text):
        return
    if normalize_jump_off_tag(state, text):
        return
    normalize_generic_remix_tag(state, text)


def consume_free_text(state, text):
    text = remove_wordplay_tokens(remove_kbpm_from_text(remove_noise_tokens(text)))
    text = re.sub(r"\bvs\.?(?=\s)", "vs", text, flags=re.IGNORECASE)
    text = remove_discarded_tag_phrases(text)
    text = normalize_spaces(text)
    if not text:
        return

    if apply_edit_from_text(state, text):
        return
    if normalize_instrumental_tag(state, text):
        return
    if normalize_acapella_tag(state, text):
        return
    if normalize_special_intro_tag(state, text):
        return
    if normalize_quick_hitter_tag(state, text):
        return
    if normalize_jump_off_tag(state, text):
        return

    transition = normalize_range_text(text)
    if transition and re.search(r"\b(trans|transition)\b", text, flags=re.IGNORECASE):
        add_main_tag(state, transition)
        return

    add_main_tag(state, normalize_artist_like_tag(text))


def derive_state(filename, in_house=False):
    parsed = split_filename(filename)
    state = FilenameState(
        artist=parsed.artist,
        song=parsed.song,
        in_house=in_house,
        explicit_acapella_intro_source=re.search(r"\bacapella\s+intro\b", filename, flags=re.IGNORECASE) is not None,
    )

    tags = parsed.main_tags
    paren_count = len(re.findall(r"\([^()]*\)", filename.split(" - ", 1)[1] if " - " in filename else ""))
    paren_tags = tags[:paren_count]
    loose_text = tags[paren_count] if len(tags) > paren_count else ""

    if not paren_tags and not re.search(r"\([^()]*\)", filename):
        song_text, trailing_text = split_song_and_loose(parsed.song)
        state.song = song_text
        consume_free_text(state, trailing_text)
    else:
        for chunk in paren_tags:
            normalize_parenthetical_chunk(state, chunk)
        consume_free_text(state, loose_text)

    state.artist = normalize_artist_names(state.artist)
    state.song = normalize_song_text(state.song)
    return state


def split_song_and_loose(text):
    working = remove_kbpm_from_text(text)
    patterns = [
        r"\bintro\s*-?\s*(?:clean|dirty)\b",
        r"\b(?:clean|dirty)\s+extended\b",
        r"\b(?:clean|dirty)\s+short\s+edit\b",
        r"\b(?:clean|dirty)\s+radio\s+edit\b",
        r"\b(?:clean|dirty)\s+ck\s+cut\b",
        r"\bquick\s+hit\s+(?:clean|dirty)\b",
        r"\b(?:clean|dirty)\b",
    ]

    trailing_parts = []
    changed = True
    while changed:
        changed = False
        for pattern in patterns:
            match = re.search(rf"(.*?)(?:\s+)({pattern})$", working, flags=re.IGNORECASE)
            if match:
                working = normalize_spaces(match.group(1))
                trailing_parts.insert(0, match.group(2))
                changed = True
                break

    return normalize_song_text(working), normalize_spaces(" ".join(trailing_parts))


def apply_vs_rule(state):
    if not re.search(r"\bvs\b", f"{state.artist} {state.song}", flags=re.IGNORECASE):
        return

    new_tags = []
    for tag in state.main_tags:
        if tag in GENERIC_REMIX_TAGS:
            continue
        cleaned_tag = remove_generic_remix_words(tag)
        if cleaned_tag != tag:
            state.remix_replaced = True
        if cleaned_tag:
            new_tags.append(cleaned_tag)

    new_tags.append("Segue")
    state.main_tags = new_tags


def finalize_main_tags(state):
    seen = set()
    unique = []
    for tag in state.main_tags:
        tag = re.sub(r"\bvip\s+flip\b", " ", tag, flags=re.IGNORECASE)
        cleaned = cleanup_bad_dash(normalize_spaces(strip_outer_parens(tag)))
        if not cleaned:
            continue
        if cleaned not in seen:
            seen.add(cleaned)
            unique.append(cleaned)
    state.main_tags = unique


def render_edit_tag(state):
    if not state.edit_tone:
        return ""
    if state.edit_kind == "intro" and not state.in_house:
        return f"Intro - {state.edit_tone}"
    if state.edit_kind == "quick_hit":
        return f"Quick Hit {state.edit_tone}"
    return state.edit_tone


def is_house_path(path):
    return any(part.lower() == "house" for part in Path(path).parts)


def clean_filename(filename, in_house=False):
    state = derive_state(filename, in_house=in_house)
    apply_vs_rule(state)
    finalize_main_tags(state)
    harmonize_edit_tag(state)

    parts = [state.artist]
    if state.song:
        parts[0] = f"{state.artist} - {state.song}"

    for tag in state.main_tags:
        parts.append(f"({tag})")

    edit_tag = render_edit_tag(state)
    if edit_tag:
        parts.append(f"({edit_tag})")

    cleaned = normalize_spaces(" ".join(parts))
    cleaned = cleaned.replace("(())", "")
    cleaned = re.sub(r"\(\s*\(", "(", cleaned)
    cleaned = re.sub(r"\)\s*\)", ")", cleaned)
    cleaned = re.sub(r"\(\s*-\s*([^)]+)\)", r"(\1)", cleaned)
    cleaned = re.sub(r"\(([^)]*?)\s*-\s*\)", r"(\1)", cleaned)
    cleaned = normalize_spaces(cleaned)
    return cleaned.strip()


def clean_filesystem_name(filename, in_house=False):
    stem, ext = os.path.splitext(filename)
    cleaned_stem = clean_filename(stem, in_house=in_house)
    return f"{cleaned_stem}{ext}"


def write_mp3_title_metadata(file_path, title):
    if Path(file_path).suffix.lower() != ".mp3":
        return

    try:
        from mutagen.easyid3 import EasyID3
        from mutagen.id3 import ID3NoHeaderError
    except ImportError as error:
        raise RuntimeError("MP3 title stamping requires the 'mutagen' package") from error

    try:
        audio = EasyID3(file_path)
    except ID3NoHeaderError:
        audio = EasyID3()
        audio["title"] = [title]
        audio.save(file_path)
        return

    audio["title"] = [title]
    audio.save()


def format_preview_block(original, cleaned, before_label="before", after_label="after"):
    before_text, after_text = build_inline_diff(original, cleaned)
    before_prefix = f"{before_label}:".rjust(7)
    after_prefix = f"{after_label}:".rjust(7)
    return "\n".join(
        [
            f"  {COLOR_RED}{before_prefix}{COLOR_RESET} {before_text}",
            f"  {COLOR_GREEN}{after_prefix}{COLOR_RESET} {after_text}",
        ]
    )


def format_delete_preview_block(original, reason):
    before_prefix = "before:".rjust(7)
    after_prefix = "after:".rjust(7)
    return "\n".join(
        [
            f"  {COLOR_RED}{before_prefix}{COLOR_RESET} {original}",
            f"  {COLOR_GREEN}{after_prefix}{COLOR_RESET} {COLOR_BRIGHT_CYAN}{DELETED_SENTINEL} * {reason}{COLOR_RESET}",
        ]
    )


def format_move_destination(destination):
    return f"  {COLOR_GREEN}{'to:'.rjust(7)}{COLOR_RESET} {colorize_sort_path(destination)}"


def colorize_sort_path(path):
    parts = Path(path).parts
    if not parts:
        return path

    colored_parts = []
    for index, part in enumerate(parts):
        if index == len(parts) - 1:
            colored_parts.append(part)
        else:
            color = SORT_FOLDER_COLORS[index % len(SORT_FOLDER_COLORS)]
            colored_parts.append(f"{color}{part}{COLOR_RESET}")
    return os.path.join(*colored_parts)


def format_sort_preview_block(original, destination):
    return "\n".join([
        f"  {COLOR_RED}{'from:'.rjust(7)}{COLOR_RESET} {colorize_sort_path(original)}",
        format_move_destination(destination),
    ])


def build_revert_footer(directory, operations):
    payload = json.dumps({"directory": directory, "operations": operations}, separators=(",", ":"))
    compressed = zlib.compress(payload.encode("utf-8"))
    encoded = base64.b64encode(compressed).decode("ascii")
    return f"{REVERT_DATA_PREFIX}{encoded}"


def write_ansi_log(directory, entries, operations, changes_made):
    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S-%f")
    logs_dir = REPO_ROOT / "logs"
    os.makedirs(logs_dir, exist_ok=True)
    log_path = logs_dir / f"rename-log-{timestamp}"
    created_at = datetime.now().isoformat(timespec='seconds')
    header = [
        f"{COLOR_GREEN}RENAME LOG{COLOR_RESET}",
        f"{COLOR_DIM}Directory: {directory}{COLOR_RESET}",
        f"{COLOR_DIM}Created:   {created_at}{COLOR_RESET}",
        f"{COLOR_DIM}Changed:   {changes_made}{COLOR_RESET}",
    ]
    footer = build_revert_footer(directory, operations)
    with open(log_path, "w", encoding="utf-8") as handle:
        handle.write("\n".join(header))
        handle.write("\n\n")
        handle.write("\n\n".join(entries))
        handle.write("\n\n")
        handle.write(footer + "\n")
    return str(log_path)


def strip_ansi(text):
    return ANSI_PATTERN.sub("", text)


def parse_revert_log(log_file):
    with open(log_file, "r", encoding="utf-8") as handle:
        contents = handle.read()

    clean_contents = strip_ansi(contents)
    footer_line = None
    for line in reversed(clean_contents.splitlines()):
        if line.startswith(REVERT_DATA_PREFIX):
            footer_line = line
            break

    if not footer_line:
        raise ValueError("Log file does not contain revert metadata")

    encoded = footer_line[len(REVERT_DATA_PREFIX):]
    payload = zlib.decompress(base64.b64decode(encoded)).decode("utf-8")
    data = json.loads(payload)
    return data["directory"], data["operations"]


def get_latest_log_file():
    logs_dir = REPO_ROOT / "logs"
    if not logs_dir.is_dir():
        raise FileNotFoundError("No logs directory found")

    log_files = [
        str(logs_dir / name)
        for name in os.listdir(logs_dir)
        if re.fullmatch(r"rename-log-\d{8}-\d{6}-\d{6}", name)
    ]

    if not log_files:
        raise FileNotFoundError("No rename logs found in logs directory")

    return max(log_files, key=os.path.basename)


def tokenize_diff_text(text):
    return re.findall(r"\s+|\(|\)|\[[^\]]*\]|[^\s()]+", text)


def build_inline_diff(original, cleaned):
    original_tokens = tokenize_diff_text(original)
    cleaned_tokens = tokenize_diff_text(cleaned)
    matcher = SequenceMatcher(a=original_tokens, b=cleaned_tokens)

    before_parts = []
    after_parts = []

    for tag, i1, i2, j1, j2 in matcher.get_opcodes():
        old_chunk = "".join(original_tokens[i1:i2])
        new_chunk = "".join(cleaned_tokens[j1:j2])

        if tag == "equal":
            before_parts.append(old_chunk)
            after_parts.append(new_chunk)
        elif tag == "delete":
            before_parts.append(f"{COLOR_RED}{old_chunk}{COLOR_RESET}")
        elif tag == "insert":
            after_parts.append(f"{COLOR_GREEN}{new_chunk}{COLOR_RESET}")
        elif tag == "replace":
            before_parts.append(f"{COLOR_RED}{old_chunk}{COLOR_RESET}")
            after_parts.append(f"{COLOR_GREEN}{new_chunk}{COLOR_RESET}")

    return "".join(before_parts), "".join(after_parts)


def classify_sort_leaf(state):
    edit_tag = render_edit_tag(state)
    if edit_tag:
        return edit_tag.replace(" - ", " ")
    return None


def classify_hip_hop_tool_path(state):
    for tag in state.main_tags:
        if tag in {"Acapella In & Out", "Acapella In", "Acapella Out", "Acapella"}:
            return os.path.join("Acapellas", tag)
        if tag == "Clapapella":
            return "Clapapella"
        if tag == "Instrumental":
            return "Instrumental"
        if tag == "Jump Off Edit":
            return "Jump Off Edit"
        if tag == "Mash":
            return "Mash"
        if tag == "Segue":
            return "Segue"
        if tag == "Slam Edit":
            return "Slam Edit"
        if tag.endswith("Transition"):
            return "Transition"
    return None


def infer_genre_root(target_dir, root):
    relative = Path(os.path.relpath(root, target_dir))
    parts = [] if str(relative) == "." else list(relative.parts)
    for part in parts:
        if part.lower() == "edm":
            return "EDM"
    for genre in ["Country", "Hip Hop", "Latin"]:
        if genre in parts:
            return genre
    return None


def build_sort_destination(target_dir, current_root, filename):
    genre = infer_genre_root(target_dir, current_root)
    if genre in (None, "EDM"):
        return None

    stem, _ = os.path.splitext(filename)
    state = derive_state(stem, in_house=genre == "House")
    apply_vs_rule(state)
    finalize_main_tags(state)
    harmonize_edit_tag(state)

    if genre == "Hip Hop":
        tool_path = classify_hip_hop_tool_path(state)
        if tool_path == "Instrumental":
            return os.path.join(target_dir, "Hip Hop Tools", tool_path, filename)
        if tool_path:
            leaf = classify_sort_leaf(state)
            if not leaf:
                return None
            return os.path.join(target_dir, "Hip Hop Tools", tool_path, leaf, filename)

    leaf = classify_sort_leaf(state)
    if not leaf:
        return None

    return os.path.join(target_dir, genre, leaf, filename)


def process_directory(directory, dry_run=True):
    changes_made = 0
    log_entries = []
    log_operations = []
    for root, _, files in os.walk(directory):
        occupied_names = set(files)
        occupied_keys = {canonical_filename_key(name) for name in files}
        for filename in files:
            original_path = os.path.join(root, filename)
            in_house = is_house_path(original_path)

            if is_duplicate_suffix_file(filename):
                original_stem, _ = os.path.splitext(filename)
                preview_block = format_delete_preview_block(original_stem, "explicit duplicate")
                if dry_run:
                    print(preview_block)
                    print()
                else:
                    os.remove(original_path)
                    log_entries.append(preview_block)
                    log_operations.append({
                        "before": os.path.relpath(original_path, directory),
                        "after": DELETED_SENTINEL,
                    })
                occupied_names.discard(filename)
                occupied_keys.discard(canonical_filename_key(filename))
                changes_made += 1
                continue

            cleaned = clean_filesystem_name(filename, in_house=in_house)
            cleaned_stem, _ = os.path.splitext(cleaned)
            if cleaned != filename:
                occupied_names.discard(filename)
                occupied_keys.discard(canonical_filename_key(filename))
                new_path = os.path.join(root, cleaned)
                original_stem, _ = os.path.splitext(filename)
                preview_block = format_preview_block(original_stem, cleaned_stem)
                cleaned_key = canonical_filename_key(cleaned)
                if cleaned_key in occupied_keys or os.path.exists(new_path):
                    delete_preview = format_delete_preview_block(original_stem, "collision")
                    if dry_run:
                        print(delete_preview)
                        print()
                    else:
                        os.remove(original_path)
                        log_entries.append(delete_preview)
                        log_operations.append({
                            "before": os.path.relpath(original_path, directory),
                            "after": DELETED_SENTINEL,
                        })
                    changes_made += 1
                    continue
                if dry_run:
                    print(preview_block)
                    print()
                if not dry_run:
                    try:
                        os.rename(original_path, new_path)
                    except OSError as error:
                        if not is_existing_destination_error(error):
                            raise
                        os.remove(original_path)
                        delete_preview = format_delete_preview_block(original_stem, "collision")
                        log_entries.append(delete_preview)
                        log_operations.append({
                            "before": os.path.relpath(original_path, directory),
                            "after": DELETED_SENTINEL,
                        })
                        changes_made += 1
                        continue
                    log_entries.append(preview_block)
                    log_operations.append({
                        "before": os.path.relpath(original_path, directory),
                        "after": os.path.relpath(new_path, directory),
                    })
                occupied_names.add(cleaned)
                occupied_keys.add(cleaned_key)
                changes_made += 1
                continue

    log_path = None
    if not dry_run and log_entries:
        log_path = write_ansi_log(directory, log_entries, log_operations, changes_made)
    return changes_made, log_path


def process_directory_tags(directory):
    changes_made = 0
    for root, _, files in os.walk(directory):
        for filename in files:
            original_path = os.path.join(root, filename)
            in_house = is_house_path(original_path)
            cleaned_stem, ext = os.path.splitext(clean_filesystem_name(filename, in_house=in_house))
            if ext.lower() != ".mp3":
                continue
            write_mp3_title_metadata(original_path, cleaned_stem)
            changes_made += 1
    return changes_made, None


def process_directory_sort(directory, dry_run=True):
    changes_made = 0
    log_entries = []
    log_operations = []
    for root, _, files in os.walk(directory):
        if any(part.lower() == "edm" for part in Path(root).parts):
            continue

        for filename in files:
            original_path = os.path.join(root, filename)
            in_house = is_house_path(original_path)
            cleaned_filename = clean_filesystem_name(filename, in_house=in_house)
            destination_filename = cleaned_filename if dry_run else filename
            destination_path = build_sort_destination(directory, root, destination_filename)
            if not destination_path or os.path.normpath(destination_path) == os.path.normpath(original_path):
                continue

            original_rel = os.path.relpath(original_path, directory)
            destination_rel = os.path.relpath(destination_path, directory)
            preview_block = format_sort_preview_block(original_rel, destination_rel)

            if dry_run:
                print(preview_block)
                print()
                changes_made += 1
                continue

            os.makedirs(os.path.dirname(destination_path), exist_ok=True)
            if os.path.exists(destination_path):
                delete_preview = format_delete_preview_block(original_rel, f"collision at {destination_rel}")
                os.remove(original_path)
                log_entries.append(delete_preview)
                log_operations.append({
                    "before": original_rel,
                    "after": DELETED_SENTINEL,
                })
            else:
                os.rename(original_path, destination_path)
                log_entries.append(preview_block)
                log_operations.append({
                    "before": original_rel,
                    "after": destination_rel,
                })
            changes_made += 1

    log_path = None
    if not dry_run and log_entries:
        log_path = write_ansi_log(directory, log_entries, log_operations, changes_made)
    return changes_made, log_path


def revert_from_log(log_file, dry_run=True):
    directory, operations = parse_revert_log(log_file)
    changes_made = 0
    log_entries = []
    revert_operations = []

    for operation in operations:
        if operation.get("action") == "delete" or operation.get("after") == DELETED_SENTINEL:
            print(f"{COLOR_RED}Cannot revert deleted duplicate file:{COLOR_RESET} {operation['before']}")
            continue

        current_name = operation["after"]
        reverted_name = operation["before"]
        current_path = os.path.join(directory, current_name)
        reverted_path = os.path.join(directory, reverted_name)

        if not os.path.exists(current_path):
            print(f"{COLOR_RED}Missing current file:{COLOR_RESET} {current_path}")
            continue

        current_stem, _ = os.path.splitext(current_name)
        reverted_stem, _ = os.path.splitext(reverted_name)
        preview_block = format_preview_block(current_stem, reverted_stem, before_label="current", after_label="revert")

        if not dry_run:
            os.makedirs(os.path.dirname(reverted_path), exist_ok=True)
            os.rename(current_path, reverted_path)
            log_entries.append(preview_block)
            revert_operations.append({
                "before": current_name,
                "after": reverted_name,
            })

        changes_made += 1

    log_path = None
    if not dry_run and log_entries:
        log_path = write_ansi_log(directory, log_entries, revert_operations, changes_made)

    return changes_made, log_path, directory


def run_tests(test_file):
    passed = 0
    failed = 0
    failed_tests = []

    with open(test_file, "r") as f:
        tests = json.load(f)

    for test in tests:
        result = clean_filename(test["input"], in_house=test.get("house", False))
        if result == test["expected"]:
            passed += 1
        else:
            failed += 1
            failed_tests.append((test["name"], test["input"], test["expected"], result))

    print(f"\n{'=' * 50}")
    print(f"Test Results: {passed} passed, {failed} failed")
    print(f"{'=' * 50}")

    if failed_tests:
        print("\nFailed tests:")
        for name, input_name, expected, result in failed_tests:
            print(f"\n  Test: {name}")
            print(f"  Input:    {input_name}")
            print(f"  Expected: {expected}")
            print(f"  Got:      {result}")

    return failed == 0


def show_test_diffs(test_file):
    with open(test_file, "r") as f:
        tests = json.load(f)

    for index, test in enumerate(tests, start=1):
        print(f"[{index}] {test['name']}")
        print(format_preview_block(test["input"], test["expected"]))
        print()

    print(f"{len(tests)} test diffs shown.")


def is_unsafe_target_dir(target_dir):
    raw = target_dir.strip()
    if raw in {".", ".."}:
        return True

    resolved_target = Path(target_dir).resolve()
    cwd = Path.cwd().resolve()
    parent = cwd.parent
    return resolved_target in {cwd, parent}


def fail_cli(message):
    print(f"Error: {message}")
    sys.exit(1)


def main():
    if len(sys.argv) > 1 and sys.argv[1] in ("--test-diff", "-d"):
        if len(sys.argv) > 3:
            fail_cli("--test-diff accepts at most one optional test file path")
        test_file = sys.argv[2] if len(sys.argv) > 2 else str(REPO_ROOT / "tests.json")
        show_test_diffs(test_file)
        return

    if len(sys.argv) > 1 and sys.argv[1] == "--test":
        if len(sys.argv) > 3:
            fail_cli("--test accepts at most one optional test file path")
        test_file = sys.argv[2] if len(sys.argv) > 2 else str(REPO_ROOT / "tests.json")
        success = run_tests(test_file)
        sys.exit(0 if success else 1)

    if len(sys.argv) > 1 and sys.argv[1] in ("--revert", "-v"):
        if len(sys.argv) > 3:
            fail_cli("--revert accepts at most one optional log path")
        log_file = None
        if len(sys.argv) > 2:
            log_file = sys.argv[2]

        if log_file is None:
            try:
                log_file = get_latest_log_file()
            except FileNotFoundError as exc:
                print(f"Error: {exc}")
                sys.exit(1)

        print(f"{COLOR_CYAN}REVERT{COLOR_RESET} {COLOR_DIM}Applying revert from {log_file}{COLOR_RESET}")
        changes, log_path, directory = revert_from_log(log_file, dry_run=False)
        print(f"\n{changes} files reverted in {directory}.")
        if log_path:
            print(f"ANSI log written to {log_path}")
        return

    if len(sys.argv) < 2:
        print("Usage:")
        print("  clean --test [file]             Run tests")
        print("  clean --test-diff|-d [file]     Preview input vs expected test diffs")
        print("  clean <dir>                     Dry run (preview changes)")
        print("  clean <dir> --run|-r            Actually rename files")
        print("  clean <dir> --tag|-t            Actually write MP3 title tags")
        print("  clean <dir> --sort|-s           Dry run sort into folders")
        print("  clean <dir> --sort|-s --run|-r  Actually sort into folders")
        print("  clean --revert|-v [log]         Revert from log or latest log")
        sys.exit(1)

    if sys.argv[1].startswith("-"):
        fail_cli(f"unknown command or flag: {sys.argv[1]}")

    target_dir = sys.argv[1]
    raw_flags = sys.argv[2:]
    valid_flags = {"--run", "-r", "--sort", "-s", "--tag", "-t"}
    invalid_flags = [flag for flag in raw_flags if flag not in valid_flags]
    if invalid_flags:
        fail_cli(f"unknown flag(s): {' '.join(invalid_flags)}")

    run_mode = "--run" in raw_flags or "-r" in raw_flags
    tag_mode = "--tag" in raw_flags or "-t" in raw_flags
    sort_mode = "--sort" in raw_flags or "-s" in raw_flags
    dry_run = not run_mode and not tag_mode

    selected_operations = []
    if sort_mode:
        selected_operations.append("sort")
    if tag_mode:
        selected_operations.append("tag")
    if len(selected_operations) > 1:
        fail_cli("multiple operation flags provided; choose only one of --sort/-s or --tag/-t")

    if is_unsafe_target_dir(target_dir):
        print("Error: refusing to run against '.' , '..', or paths that resolve to the current or parent directory.")
        print("Pass a specific target folder instead.")
        sys.exit(1)

    if dry_run:
        print(f"{COLOR_CYAN}DRY RUN{COLOR_RESET} {COLOR_DIM}No changes will be made. Use --run to apply changes.{COLOR_RESET}")
        print()
    else:
        if tag_mode:
            action = "Writing MP3 title tags in"
        elif sort_mode:
            action = "Sorting files in"
        else:
            action = "Renaming files in"
        print(f"{COLOR_CYAN}RUN{COLOR_RESET} {COLOR_DIM}{action} {target_dir}{COLOR_RESET}")

    if tag_mode:
        changes, log_path = process_directory_tags(target_dir)
    elif sort_mode:
        changes, log_path = process_directory_sort(target_dir, dry_run=dry_run)
    else:
        changes, log_path = process_directory(target_dir, dry_run=dry_run)

    if dry_run:
        print(f"\n{changes} files would be changed. Run with --run to apply.")
    else:
        print(f"\n{changes} files changed.")
        if log_path:
            print(f"ANSI log written to {log_path}")


if __name__ == "__main__":
    main()
